rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public website reads from these collections.
    match /services/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /appointments/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Deny anything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
